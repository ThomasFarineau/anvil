{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "{{name}}",
  "version": "1.0.0",
  "identifier": "{{identifier}}",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Launcher",
        "width": 1000,
        "height": 660,
        "minWidth": 800,
        "minHeight": 520,
        "resizable": true,
        "fullscreen": false,
        "decorations": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "appimage", "dmg"],
    "resources": {
      "../config.json": "config.json"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
