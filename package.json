{
  "name": "@thomasfarineau/anvil",
  "version": "0.0.4",
  "description": "Zero-config Minecraft launcher framework built on Tauri",
  "keywords": [
    "launcher",
    "minecraft",
    "tauri"
  ],
  "license": "MIT",
  "bin": {
    "anvil": "dist/cli.cjs",
    "create-anvil": "dist/cli.cjs"
  },
  "workspaces": [
    "server"
  ],
  "files": [
    "dist/",
    "src/template/",
    "src/rust/",
    "src/client/"
  ],
  "type": "module",
  "scripts": {
    "build": "bun build ./src/cli/index.ts --target node --format cjs --packages external --outfile dist/cli.cjs",
    "prepack": "bun run build",
    "test": "bun test",
    "lint": "oxlint .",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "check": "bun run build && bun run lint && bun run format:check && bun test",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs"
  },
  "dependencies": {
    "@clack/prompts": "^1.7.0",
    "@tauri-apps/cli": "^2.11.4",
    "commander": "^15.0.0",
    "sharp": "^0.35.3"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "bun": "^1.3.14",
    "oxfmt": "^0.58.0",
    "oxlint": "^1.73.0",
    "vitepress": "^1.6.4"
  },
  "engines": {
    "node": ">=18"
  }
}
